NODE_ENV=development
PORT=10000

DATABASE_URL="postgresql://sandbox:sandbox@localhost:55432/sandbox_hotel_dev?schema=public"
E2E_DATABASE_URL="postgresql://sandbox:sandbox@localhost:55432/sandbox_hotel_e2e?schema=public"
ALLOW_DB_E2E=false

VITE_PMS_API_MODE=server
SESSION_SECRET=replace-with-a-long-local-secret

SEED_MODE=dev
SEED_USERS_JSON=
SEED_ADMIN_EMAIL=
ALLOW_PROD_ROOM_ONBOARDING=false

# Set one of these legacy values only if you want to bypass the first-run setup wizard locally.
SEED_ADMIN_PASSWORD=
SEED_ADMIN_PASSWORD_HASH=
SEED_USER_PASSWORD_HASH=

LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Booking email intake. Do not store the Gmail account password here.
BOOKING_EMAIL_PRIMARY_MAILBOX=booking@sandboxhotel.com
BOOKING_EMAIL_GMAIL_USER_ID=me
BOOKING_EMAIL_GMAIL_ACCESS_TOKEN=
