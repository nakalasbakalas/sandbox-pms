APP_ENV=production
PREFERRED_URL_SCHEME=https
MARKETING_SITE_URL=https://www.sandboxhotel.com
BOOKING_ENGINE_URL=https://book.sandboxhotel.com
STAFF_APP_URL=https://staff.sandboxhotel.com
# Keep this equal to BOOKING_ENGINE_URL in production.
APP_BASE_URL=https://book.sandboxhotel.com
FORCE_HTTPS=1
ENFORCE_CANONICAL_HOSTS=1
TRUSTED_HOSTS=book.sandboxhotel.com,staff.sandboxhotel.com
AUTH_COOKIE_SECURE=1
SESSION_COOKIE_SECURE=1
DATABASE_URL=
SECRET_KEY=
# Fernet key for MFA secrets and encrypted auth/iCal tokens.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AUTH_ENCRYPTION_KEY=
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=reservations@sandboxhotel.com
PAYMENT_PROVIDER=
PAYMENT_LINK_TTL_MINUTES=60
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_API_BASE=https://api.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SMTP_PORT=587
SMTP_USE_TLS=1
STAFF_ALERT_EMAILS=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
AUDIT_LOG_RETENTION_DAYS=0

# Document storage — choose one approach:
# Option A: Local persistent disk
# UPLOAD_DIR=/var/data/uploads/documents
# Option B: S3-compatible storage
# STORAGE_BACKEND=s3
# S3_BUCKET=
# S3_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Upload size limit (12 MB = 12582912 bytes, must match pre-check-in 10 MB doc limit)
MAX_CONTENT_LENGTH=12582912
