APP_ENV=production
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_32_PLUS_CHARS
DATABASE_URL=postgresql+psycopg://REPLACE_WITH_RENDER_POSTGRES_URL
SERVER_NAME=
PREFERRED_URL_SCHEME=https
APPLICATION_ROOT=/
FORCE_HTTPS=1
TRUST_PROXY_COUNT=1
TRUSTED_HOSTS=sandboxhotel.com,sandbox-pms-prod.onrender.com
LOG_LEVEL=INFO
ENABLE_ACCESS_LOGGING=1
ENABLE_SECURITY_HEADERS=1
HSTS_MAX_AGE_SECONDS=31536000
CONTENT_SECURITY_POLICY="default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data: https:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
MAX_CONTENT_LENGTH=1048576
MAX_FORM_MEMORY_SIZE=262144
MAX_FORM_PARTS=200
PAYMENT_BASE_URL=
PAYMENT_PROVIDER=disabled
PAYMENT_LINK_TTL_MINUTES=60
PAYMENT_LINK_RESEND_COOLDOWN_SECONDS=60
PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_API_BASE=https://api.stripe.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
TEST_HOSTED_PAYMENT_SECRET=prod-not-used
APP_BASE_URL=https://sandboxhotel.com
AUTO_BOOTSTRAP_SCHEMA=0
AUTO_SEED_REFERENCE_DATA=0
INVENTORY_BOOTSTRAP_DAYS=730
RESERVATION_CODE_PREFIX=SBX
ADMIN_EMAIL=admin@sandboxhotel.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
AUTH_COOKIE_NAME=sbx_staff_session
AUTH_COOKIE_SECURE=1
AUTH_COOKIE_SAMESITE=Lax
AUTH_ENCRYPTION_KEY=REPLACE_WITH_VALID_FERNET_KEY
SESSION_COOKIE_NAME=sbx_browser_state
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
SESSION_IDLE_MINUTES=15
SESSION_ABSOLUTE_HOURS=8
PASSWORD_RESET_TTL_MINUTES=45
PASSWORD_RESET_REQUEST_LIMIT=3
PASSWORD_RESET_REQUEST_WINDOW_MINUTES=60
LOGIN_LOCK_THRESHOLD=5
LOGIN_LOCK_WINDOW_MINUTES=15
LOGIN_LOCK_DURATION_MINUTES=15
MFA_VERIFY_WINDOW=1
MFA_ISSUER="Sandbox Hotel PMS"
AUTH_SHOW_RESET_LINKS=0
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=2
ARGON2_HASH_LEN=32
PUBLIC_BOOKING_HOLD_MINUTES=7
PUBLIC_BOOKING_RATE_LIMIT_WINDOW_MINUTES=15
PUBLIC_BOOKING_RATE_LIMIT_COUNT=10
PUBLIC_LOOKUP_RATE_LIMIT_COUNT=8
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1
MAIL_FROM=reservations@sandboxhotel.com
STAFF_ALERT_EMAILS=
LINE_STAFF_ALERT_WEBHOOK_URL=
WHATSAPP_STAFF_ALERT_WEBHOOK_URL=
PG_DUMP_BIN=pg_dump
PG_RESTORE_BIN=pg_restore
BACKUP_RETENTION_DAYS=14
BACKUP_ENCRYPTION_REQUIRED=1
RESTORE_VERIFY_COMMAND=
TEST_DATABASE_URL=
