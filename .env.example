NODE_ENV=production
PORT=10000

# Runtime database. Render production should inject this from the managed
# PostgreSQL database binding; do not commit a live production URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sandbox_hotel_pms?schema=public"

# Only used by the guarded database-mutating E2E command.
E2E_DATABASE_URL="postgresql://sandbox:sandbox@localhost:55432/sandbox_hotel_e2e?schema=public"
ALLOW_DB_E2E=false

# Set to "server" in deployed environments to use backend-authenticated API sessions.
VITE_PMS_API_MODE=server

# Public production URL and browser origins allowed to call /api/*.
APP_URL=https://sandbox-hotel-pms.onrender.com
ALLOWED_ORIGINS=https://sandbox-hotel-pms.onrender.com

# Keep public setup disabled in production unless a one-time token is provided.
# Send the token as x-setup-token or a Bearer token when completing first-run setup.
INITIAL_SETUP_TOKEN=
ALLOW_PUBLIC_SETUP=false

# Enable only when all traffic reaches the app through a trusted proxy that
# overwrites client IP headers. Otherwise login throttling uses the socket IP.
TRUST_PROXY_HEADERS=false

# Required for signed backend sessions. Render can generate this from render.yaml.
# For other platforms, generate an ignored local bundle with:
# npm run prod:credentials
SESSION_SECRET=change-me-before-production

# Application-layer login throttling. Keep these enabled even when an upstream
# WAF or platform rate limit is configured.
LOGIN_THROTTLE_WINDOW_MS=900000
LOGIN_LOCKOUT_MS=900000
LOGIN_ACCOUNT_MAX_ATTEMPTS=5
LOGIN_IP_MAX_ATTEMPTS=20

# Seed modes: dev, e2e, prod-safe. Production Render should use prod-safe.
SEED_MODE=prod-safe

# Required only for the explicit production room inventory import command.
ALLOW_PROD_ROOM_ONBOARDING=false

# Preferred production user seed. Use only approved real staff accounts, and
# store passwordHash values generated with npm run security:hash-password.
SEED_USERS_JSON=

# Legacy single bootstrap admin. Prefer SEED_USERS_JSON for real staff setup.
# Set an email plus either a hash or password. Prefer the hash so a temporary
# password is never stored in platform env history.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD_HASH=
SEED_USER_PASSWORD_HASH=
SEED_ADMIN_PASSWORD=

# Optional development-only admin seed. Prefer first-run setup for local use.

# Required before enabling live LINE guest/staff messaging.
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Optional Hotel Ops command intake from signed LINE webhooks. Inbound LINE
# messages are only converted to Ops tasks when enabled, prefixed, and mapped to
# an existing active PMS user with create:ops-task permission.
HOTEL_OPS_LINE_COMMANDS_ENABLED=false
HOTEL_OPS_LINE_COMMAND_PREFIX=/ops
HOTEL_OPS_LINE_COMMAND_USER_MAP={}

# Optional Hotel Ops command intake from synced booking mailbox messages.
# Messages are only converted to Ops tasks when enabled, prefixed, and mapped by
# sender email to an existing active PMS user with create:ops-task permission.
HOTEL_OPS_EMAIL_COMMANDS_ENABLED=false
HOTEL_OPS_EMAIL_COMMAND_PREFIX=/ops
HOTEL_OPS_EMAIL_COMMAND_USER_MAP={}

# Hotel Ops OTA worker. Keep dry-run enabled until OTA credentials, selectors,
# 2FA handling, and proof screenshots are verified against a safe test account.
OTA_DRY_RUN=true
OTA_WORKER_BASE_URL=
OTA_WORKER_SHARED_SECRET=

# In-process Hotel Ops scans are interval-only. Cron expressions are stored as
# an external scheduler contract; cron execution must call POST /api/ops/scan/run.
HOTEL_OPS_SCAN_INTERVAL_MINUTES=
HOTEL_OPS_SCAN_CRON=

# Optional backend-only Hotel Ops AI parser. Keep unset to use the deterministic
# parser. OPENAI_API_KEY must be a backend secret and is never sent to frontend.
HOTEL_OPS_AI_PARSER_ENABLED=false
HOTEL_OPS_AI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=

# Optional backend-only Hotel Ops email delivery. Default behavior records email
# intents as provider-pending. Enable only after Gmail OAuth credentials below
# are configured as backend/platform secrets.
HOTEL_OPS_EMAIL_DELIVERY_ENABLED=false
HOTEL_OPS_EMAIL_PROVIDER=gmail
HOTEL_OPS_EMAIL_FROM=booking@sandboxhotel.com
HOTEL_OPS_GMAIL_USER_ID=me

# Booking.com adapter credentials are read only by backend adapter code. The
# BOOKING_USERNAME/BOOKING_PASSWORD aliases are also supported for compatibility.
BOOKING_USERNAME=
BOOKING_PASSWORD=
BOOKING_COM_USERNAME=
BOOKING_COM_PASSWORD=
BOOKING_FORCE_HUMAN_CHALLENGE=
OTA_ENABLE_REAL_BROWSER_WRITES=false

# Booking email intake. Keep the primary mailbox explicit, but do not store a
# Gmail account password here. Server sync requires either an OAuth access token
# or backend OAuth refresh-token credentials with the Gmail API enabled.
BOOKING_EMAIL_PRIMARY_MAILBOX=booking@sandboxhotel.com
BOOKING_EMAIL_GMAIL_USER_ID=me
BOOKING_EMAIL_GMAIL_ACCESS_TOKEN=
BOOKING_EMAIL_GMAIL_CLIENT_ID=
BOOKING_EMAIL_GMAIL_CLIENT_SECRET=
BOOKING_EMAIL_GMAIL_REFRESH_TOKEN=
