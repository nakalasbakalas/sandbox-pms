NODE_ENV=production
PORT=10000

# Render should inject this from the managed PostgreSQL database.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/sandbox_hotel_pms?schema=public

# Set to "server" in deployed environments to use backend-authenticated API sessions.
VITE_PMS_API_MODE=server

# Required for signed backend sessions. Generate a long random value per environment.
SESSION_SECRET=change-me-before-production

# Bootstrap admin path for a fresh deploy. Set either `SEED_ADMIN_PASSWORD` or `SEED_USER_PASSWORD_HASH`.
# Prefer the hash for production so the temporary password is never stored in Render env history.
# Passwords must be at least 12 characters and are never printed by the seed script.
SEED_ADMIN_PASSWORD=
SEED_USER_PASSWORD_HASH=

# Optional: add these only if you want to seed additional staff users during initial bootstrap.
SEED_MANAGER_PASSWORD=
SEED_FRONT_DESK_PASSWORD=
SEED_HOUSEKEEPING_PASSWORD=
SEED_CASHIER_PASSWORD=

# Required before enabling live LINE guest/staff messaging.
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Enable only against a disposable/staging database.
PMS_E2E_MUTATE_DB=0
